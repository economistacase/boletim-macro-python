{
  "permissions": {
    "allow": [
      "Bash(python:*)",
      "Bash(quarto:*)",
      "Read(**)",
      "Write(**)",
      "Edit(**)",
      "WebFetch"
    ],
    "ask": [
      "Bash(git:*)",
      "Bash(gh:*)"
    ],
    "deny": [
      "Bash(rm:*)",
      "Bash(sudo:*)",
      "Bash(curl:*)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "python python/hook_log.py"
          }
        ]
      }
    ]
  }
}
